# Optional — enables per-user cloud sync + auth (Convex + Clerk).
# Leave BOTH unset to run the app in local-only mode (localStorage, no sign-in).

# From `npx convex dev` (written to .env.local automatically) or the Convex dashboard:
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# From the Clerk dashboard → API Keys → Publishable key:
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# NOTE: also set CLERK_JWT_ISSUER_DOMAIN in the Convex dashboard
# (Settings → Environment Variables) to your Clerk Frontend API URL,
# e.g. https://your-app.clerk.accounts.dev — see the "convex" JWT template in Clerk.
